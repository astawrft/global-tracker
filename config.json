{
  "scoring": {
    "mode": "max_norm",
    "formula_higher_better": "value / max(country_values)",
    "formula_lower_better": "1 - (value / max(country_values))",
    "clamp_0_1": true,
    "round_points_to": 2,
    "missing_value_policy": "zero",
    "notes": "For each metric: normalized ∈ [0,1]. points = normalized * max_points. weighted_points = points * weight."
  },

  "category_weights": {
    "Economy": 0.30,
    "Military": 0.25,
    "Tech": 0.20,
    "Energy": 0.10,
    "Demographics": 0.10,
    "Diplomacy": 0.05,
    "Infrastructure": 0.00
  },

